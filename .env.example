# =============================================================================
# SEM Keyword Pro — Environment Variables
# =============================================================================
# This file documents all environment variables used by the application.
# Copy to .env and fill in the values for your environment.

# --- Manus Platform (Production on Manus) ---
# Manus OAuth server URL (required for login)
OAUTH_SERVER_URL=
# Manus App ID (required for OAuth)
VITE_APP_ID=
# JWT secret for session cookies (required for auth)
JWT_SECRET=
# Owner's Manus Open ID (auto-assigned admin role)
OWNER_OPEN_ID=

# --- LLM Configuration (OpenAI-compatible) ---
# Custom LLM API endpoint. If set, overrides the Manus Forge API.
# Example for DeepSeek: https://api.deepseek.com
# Example for OpenRouter: https://openrouter.ai/api
LLM_API_URL=
# Custom LLM API key. If set, overrides BUILT_IN_FORGE_API_KEY.
LLM_API_KEY=
# Custom LLM model name. Default: gemini-2.5-flash
# Example: deepseek-chat, gpt-4o, claude-sonnet-4-20250514
LLM_MODEL=

# --- Manus Forge API (fallback when LLM_API_URL is not set) ---
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# --- Database ---
# MySQL connection string (e.g., mysql://user:pass@host:3306/dbname)
DATABASE_URL=

# --- Node Environment ---
# Set to "production" in production, leave unset for development
NODE_ENV=development

# --- Server ---
# HTTP port (default: 3000)
PORT=3000
